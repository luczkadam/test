from pydantic import BaseModel

class DayPlan(BaseModel):
    title: str
    activities: list[str]

class TravelPlanResponse(BaseModel):
    chain_of_thought: str
    days: list[DayPlan]
    logistics: list[str]

system_prompt = """
Jesteś asystentem planowania podróży.
1. Przeanalizuj podane notatki używając techniki Chain of Thought (myśl krok po kroku).
2. Na ich podstawie stwórz przejrzysty i uporządkowany plan podróży.
3. Wygeneruj logiczny plan dnia oraz sekcję logistyczną (budżet, transport, noclegi).
"""

notes = """Zakopane: Dolina Chochołowska. Trekking.
Kraków: Wawel, Stare Miasto, smocza jama.
terminy: 3 dni na góry, 2 dni na miasto
Budżet 3000 zł na cały wyjazd. Noclegi do znalezienia blisko centrum.
Obiady lokalne - knajpy w centrum..
Zakupy? Czas na kupienie pamiątek.
Co z transportem? Sprawdzić bilety na pociąg/autobus."""

messages = [
    {"role": "system", "content": system_prompt},
    {"role": "user", "content": notes}
]

response = call_api(
    messages=messages,
    response_model=TravelPlanResponse
)

print(response.chain_of_thought, "\n")
for day in response.days:
    print(day.title)
    for act in day.activities:
        print(f"- {act}")
    print()
print("Logistyka:")
for log in response.logistics:
    print(f"- {log}")
