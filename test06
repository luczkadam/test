from pydantic import BaseModel, RootModel
from typing import List

# 1. Definicja modelu pojedynczego atrybutu (tak jak wcześniej)
class PersonAttribute(BaseModel):
    name: str
    value: str

# 2. Używamy RootModel, aby poinformować Pydantic, 
# że JSON jest listą obiektów, a nie obiektem z listą w środku
class PersonList(RootModel):
    root: List[PersonAttribute]

# 3. Symulacja odpowiedzi AI, która zwraca całą listę wyników
mocked_llm_output = '''
[
  {"name": "rola", "value": "PM"},
  {"name": "lokalizacja", "value": "Łódź"},
  {"name": "rola", "value": "Developer"},
  {"name": "lokalizacja", "value": "Warszawa"}
]
'''

# 4. Parsowanie - teraz Pydantic zrozumie, że to lista
data = PersonList.model_validate_json(mocked_llm_output)

# 5. Iteracja po wielu wynikach
print(f"Znaleziono {len(data.root)} wyników:\n")
for item in data.root:
    print(f"{item.name.capitalize()}: {item.value}")
