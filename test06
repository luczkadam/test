from pydantic import RootModel
from typing import List

# Twój model atrybutu pozostaje bez zmian
class PersonAttribute(BaseModel):
    name: str
    value: str

# KLUCZOWY ZMIANA: Używamy RootModel, żeby Pydantic wiedział, 
# że oczekujemy listy na samym początku dokumentu JSON
class PersonList(RootModel):
    root: List[PersonAttribute]

# Teraz, gdy przekażesz JSON w formie listy:
mock_json = '[{"name": "rola", "value": "PM"}, {"name": "lokalizacja", "value": "Łódź"}]'

# Pydantic poprawnie rozpozna, że to jest lista elementów
results = PersonList.model_validate_json(mock_json)

# Teraz możesz iterować po wynikach bezpośrednio:
for item in results.root:
    print(item.name, item.value)
