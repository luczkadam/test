def mock_llm(prompt: str) -> str:
    if "Analiza" in prompt:
        return "Imię: Jan\nZainteresowania: Podróże, Fotografia\nOstatni zakup: Aparat Sony A7 III"
    elif "Szkic" in prompt:
        return "Cześć Jan! Widzieliśmy, że kupiłeś Aparat Sony A7 III. Ponieważ lubisz fotografię i podróże, mamy dla Ciebie super ofertę na obiektywy!"
    elif "Gotowy" in prompt:
        return "Szanowny Panie Janie,\n\nMamy nadzieję, że nowy Aparat Sony A7 III sprawdza się w podróżach. Przygotowaliśmy dla Pana specjalną ofertę na akcesoria fotograficzne.\n\nPozdrawiamy serdecznie,\nZespół Obsługi Klienta"
    return ""

user_data = "{imie: 'Jan', zainteresowania: ['Podróże', 'Fotografia'], ostatni_zakup: 'Aparat Sony A7 III'}"

step1 = mock_llm(f"KROK 1. Analiza profilu: {user_data}")
print(f"--- KROK 1: Analiza ---\n{step1}\n")

step2 = mock_llm(f"KROK 2. Szkic wiadomości do klienta: {step1}")
print(f"--- KROK 2: Szkic ---\n{step2}\n")

step3 = mock_llm(f"KROK 3. Gotowy, sformatowany e-mail: {step2}")
print(f"--- KROK 3: Gotowy e-mail ---\n{step3}")
