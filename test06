import json
from openai import OpenAI

client = OpenAI()

system_prompt = """
Zwróć WYŁĄCZNIE poprawny obiekt JSON z kluczami "department" i "reason".
Dostępne działy: 'dział techniczny', 'dział sprzedaży', 'ogólny'.
Niejasne zapytania kieruj do 'ogólny'. Uzasadnienie (reason) to max 1 zdanie.
"""

queries = [
    "Aplikacja wyrzuca błąd 500 przy logowaniu.",
    "Chciałbym kupić licencję Enterprise dla 50 osób.",
    "W jakich godzinach pracujecie?"
]

for q in queries:
    response = client.chat.completions.create(
        model="gpt-3.5-turbo",
        response_format={"type": "json_object"},
        messages=[
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": q}
        ]
    )
    
    result = json.loads(response.choices[0].message.content)
    print(f"{q}\n-> {result['department']} ({result['reason']})\n")
