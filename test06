import json
import re

def parse_job_title_local(title: str) -> dict:
    role_match = re.search(r'\] (.*?) \(', title)
    role = role_match.group(1) if role_match else None
    
    skills = ["Power BI"] if "Power BI" in title else []
    languages = ["English"] if "English" in title else []
    
    result = {
        "original_title": title,
        "Job Role": role,
        "Seniority Level": None,
        "Contract Type": None,
        "Location / Work Mode": None,
        "Specialization": "Reporting and Finance" if "Finance" in title else None,
        "Industry": None,
        "Technical Skills": skills,
        "Language Requirement": languages
    }
    
    return result

title = "[CTG] Reporting and Finance Business Partner (Fluent English, Power BI)"
parsed_data = parse_job_title_local(title)

print(json.dumps(parsed_data, indent=2))
