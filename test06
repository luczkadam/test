from pydantic import BaseModel, RootModel
from typing import List

# 1. Definicja modelu pojedynczego elementu (np. atrybutu osoby lub produktu)
class ExtractedItem(BaseModel):
    name: str
    value: str

# 2. Definicja modelu głównego jako RootModel (to jest klucz do otrzymania listy wyników)
class ExtractedList(RootModel):
    root: List[ExtractedItem]

# 3. Symulacja odpowiedzi AI, która zwraca listę elementów
# Zwróć uwagę, że JSON zaczyna się od '[' (to jest lista, a nie obiekt {})
mocked_llm_output = '''
[
  {"name": "rola", "value": "PM"},
  {"name": "lokalizacja", "value": "Łódź"},
  {"name": "umiejętność", "value": "Scrum"},
  {"name": "doświadczenie", "value": "8 lat"}
]
'''

# 4. Parsowanie odpowiedzi
# Pydantic zrozumie, że to jest lista elementów typu ExtractedItem
data = ExtractedList.model_validate_json(mocked_llm_output)

# 5. Iteracja po wynikach
# Teraz mamy bezpośredni dostęp do listy przez data.root
print(f"Znaleziono {len(data.root)} atrybutów:\n")
for item in data.root:
    print(f"{item.name.capitalize()}: {item.value}")
