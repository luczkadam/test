import json
from pydantic import BaseModel
from typing import List

# 1. Struktura dla pojedynczego składnika
class Ingredient(BaseModel):
    name: str
    amount: float
    unit: str

# 2. Struktura dla pojedynczego kroku przygotowania
class Step(BaseModel):
    step_number: int
    description: str

# 3. Główna struktura potrawy (zawiera listy składników i kroków)
class Dish(BaseModel):
    dish_name: str
    ingredients: List[Ingredient]
    steps: List[Step]

# Pobranie schematu JSON dla głównego modelu (Pydantic V2)
schema = Dish.model_json_schema()

# Wyświetlenie struktury na konsoli
print(json.dumps(schema, indent=2))
