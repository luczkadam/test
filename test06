import json

system_prompt = """
Jesteś precyzyjnym asystentem kulinarnym. Otrzymasz listę składników z miarami domowymi (np. szklanki, łyżki).
Twoim zadaniem jest przeliczenie tych miar na precyzyjne miary wagowe lub objętościowe (gramy dla ciał stałych, mililitry dla płynów).

Zwróć WYŁĄCZNIE poprawny obiekt JSON.
Struktura JSON:
{
  "zakupy": [
    {"produkt": "nazwa", "ilość": liczba_całkowita, "jednostka": "g / ml / szt."}
  ]
}
"""

lista_wejsciowa = """
Oto lista zakupów:
1 szklanka mąki pszennej
2 szklanki mleka
2 jajka
3 łyżki oleju
1 szczypta soli
"""

def mock_llm_call(system: str, user: str) -> str:
    # Symulujemy odpowiedź modelu, który poprawnie przeliczył szklanki i łyżki na gramy i mililitry
    return '''
    {
      "zakupy": [
        {"produkt": "mąka pszenna", "ilość": 150, "jednostka": "g"},
        {"produkt": "mleko", "ilość": 500, "jednostka": "ml"},
        {"produkt": "jajka", "ilość": 2, "jednostka": "szt."},
        {"produkt": "olej", "ilość": 45, "jednostka": "ml"},
        {"produkt": "sól", "ilość": 1, "jednostka": "g"}
      ]
    }
    '''

# 1. Przekazanie promptu i danych użytkownika do "modelu"
response_text = mock_llm_call(system_prompt, lista_wejsciowa)

# 2. Odczytanie zwróconego tekstu jako pełnoprawny obiekt JSON
wyekstrahowane_dane = json.loads(response_text)

# 3. Wypisanie wyniku
print("--- PRZELICZONA LISTA ZAKUPÓW ---")
print(json.dumps(wyekstrahowane_dane, indent=2, ensure_ascii=False))
