import json

def mock_ai_response(query):
    if "błąd" in query.lower():
        return '{"department": "dział techniczny", "reason": "Zgłoszenie błędu aplikacji."}'
    elif "kupić" in query.lower():
        return '{"department": "dział sprzedaży", "reason": "Zainteresowanie zakupem."}'
    return '{"department": "ogólny", "reason": "Pytanie ogólne."}'

queries = [
    "Aplikacja wyrzuca błąd 500 przy logowaniu.",
    "Chciałbym kupić licencję Enterprise dla 50 osób.",
    "W jakich godzinach pracujecie?"
]

for q in queries:
    response_text = mock_ai_response(q)
    result = json.loads(response_text)
    print(f"{q}\n-> {result['department']} ({result['reason']})\n")
