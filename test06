import json

tools = [
    {
        "name": "analyze_sentiment",
        "description": "Analizuje wydźwięk podanego tekstu (pozytywny, negatywny, neutralny)."
    },
    {
        "name": "get_geolocation",
        "description": "Pobiera współrzędne geograficzne na podstawie nazwy miasta."
    }
]

def get_geolocation(city: str) -> dict:
    db = {
        "Warszawa": {"lat": 52.2297, "lon": 21.0122},
        "Kraków": {"lat": 50.0647, "lon": 19.9450}
    }
    return db.get(city, {"error": "Brak danych"})

def mock_agent(query: str) -> str:
    if "Kraków" in query:
        called_tool = tools[1]["name"]
        tool_result = get_geolocation("Kraków")
        return f"Wywołano narzędzie: {called_tool}\nZwrócone dane: {json.dumps(tool_result, indent=2)}"
    return "Nie użyto żadnego narzędzia."

print(mock_agent("Jakie są współrzędne dla miasta Kraków?"))
