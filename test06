from jinja2 import Template

template_string = """
{% if available_tools %}
## Available Tools:
<tools>
{% for tool in available_tools %}
{{ loop.index }}. {{ tool.name }}: {{ tool.description }}
{% endfor %}
</tools>
{% else %}
No tools available for this task.
{% endif %}
"""

template = Template(template_string)

tools = [
    {"name": "search_web", "description": "Searches the web for up-to-date information."},
    {"name": "run_python_code", "description": "Executes a given snippet of Python code."},
    {"name": "check_calendar", "description": "Checks for available slots in the user's calendar."}
]

with_tools = template.render(available_tools=tools)
print("--- WITH TOOLS ---")
print(with_tools)

without_tools = template.render(available_tools=[])
print("\n--- WITHOUT TOOLS ---")
print(without_tools)
