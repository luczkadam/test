from pydantic import BaseModel

class Day(BaseModel):
    title: str
    tasks: list[str]

class Plan(BaseModel):
    cot: str
    days: list[Day]

system_prompt = "Jesteś organizatorem podróży. Przeanalizuj notatki używając Chain of Thought (pole 'cot'), a następnie wygeneruj uporządkowany plan w podziale na dni."

messages = [
    {"role": "system", "content": system_prompt},
    {"role": "user", "content": "Zakopane: Dolina Chochołowska. Kraków: Wawel, Stare Miasto. 3 dni góry, 2 dni miasto. Budżet 3000 zł. Obiady w centrum, pamiątki, sprawdzić bilety."}
]

response = call_api(
    messages=messages,
    response_model=Plan
)

print(f"--- ANALIZA CoT ---\n{response.cot}\n")
for d in response.days:
    print(d.title)
    for t in d.tasks:
        print(f"- {t}")
