from openai import OpenAI

client = OpenAI()

cv_data = "Doświadczenie: 3 lata Python, podstawy SQL i Dockera."
job_offer = "Wymagania: Python Developer, relacyjne bazy danych, konteneryzacja (Docker)."

system_prompt = """Jesteś ekspertem optymalizacji CV. NIE WYMYŚLAJ DOŚWIADCZENIA.
Kroki: 1. Wypisz wymagania z ogłoszenia. 2. Oznacz w stosunku do CV: ✅/⚠️/❌. 3. Przeformułuj CV pod ATS.
Format wyjścia: ### Dopasowanie | ### Zoptymalizowane CV | ### Co zmieniono | ### Sugestie"""

messages = [
    {"role": "system", "content": system_prompt},
    {"role": "user", "content": f"Zoptymalizuj CV pod tę ofertę.\nCV:\n{cv_data}\n\nOFERTA:\n{job_offer}"}
]

response = client.chat.completions.create(model="gpt-4o", messages=messages)
print(response.choices[0].message.content)
