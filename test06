import json
from openai import OpenAI

client = OpenAI()

def parse_job_title(job_title: str, attribute_list: str) -> dict:
    system_prompt = f"""You are an expert at parsing job titles and extracting structured information.

## Attributes to Extract:
{attribute_list}

## Rules:
1. Extract ONLY information explicitly stated in the job title.
2. Never infer or assume - if not stated -> null.
3. For list-type attributes (e.g. skills, tools) -> return a JSON array.
4. Copy values exactly as they appear in the title (no paraphrasing).
5. Return ONLY valid JSON - no markdown fences, no explanations.

## Output Format:
{{
  "original_title": "<exact job title as provided>",
  "<attribute_name>": "<extracted value or null>",
  "<attribute_name>": ["<value1>", "<value2>"]
}}
"""
    
    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": job_title}
    ]
    
    response = client.chat.completions.create(
        model="gpt-3.5-turbo",
        response_format={"type": "json_object"},
        messages=messages
    )
    
    return json.loads(response.choices[0].message.content)

