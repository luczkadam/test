from enum import Enum
from pydantic import BaseModel
from openai import OpenAI

client = OpenAI()

class SpeakerRole(str, Enum):
    agent = "AI Agent"
    client = "Klient"

class DialogueTurn(BaseModel):
    speaker: SpeakerRole
    content: str

class Scenario(BaseModel):
    title: str
    dialogue: list[DialogueTurn]

class DialogueGenerationResponse(BaseModel):
    scenarios: list[Scenario]

def call_api(messages, response_model):
    completion = client.beta.chat.completions.parse(
        model="gpt-4o",
        messages=messages,
        response_format=response_model
    )
    return completion.choices[0].message.parsed

system_prompt = """
Jesteś ekspertem w tworzeniu scenariuszy dialogów.
1. Zbuduj 3 różne scenariusze rezerwacji stolika w restauracji.
2. Każdy dialog musi być rozbudowany i składać się z 5-7 tur.
3. Przewidź różne sytuacje (np. udana rezerwacja, brak miejsc na wybraną godzinę, problem z odnalezieniem rezerwacji).
"""

messages = [{"role": "system", "content": system_prompt}]

response = call_api(messages, DialogueGenerationResponse)

for scenario in response.scenarios:
    print(f"\n--- {scenario.title.upper()} ---")
    for turn in scenario.dialogue:
        print(f"[{turn.speaker.value}] - {turn.content}")
