import json
from pydantic import BaseModel
from typing import List

# 1. Definicja schematu
class Dish(BaseModel):
    dish: str
    ingredients: List[str]
    steps: List[str]

# 2. Funkcja mockująca (zastępuje wywołanie API)
def call_api(messages: list, functions: list) -> str:
    return '''
    {
      "dish": "Spaghetti Carbonara",
      "ingredients": [
        "200g makaronu spaghetti",
        "100g guanciale (lub boczku)",
        "2 duże jajka",
        "50g sera Pecorino Romano",
        "Świeżo zmielony czarny pieprz",
        "Sól (do wody)"
      ],
      "steps": [
        "Ugotuj makaron w mocno osolonej wodzie al dente.",
        "Pokrój guanciale i podsmaż na suchej patelni.",
        "Wymieszaj jajka z serem i pieprzem.",
        "Odcedź makaron i wrzuć na patelnię z guanciale. Wymieszaj.",
        "Zdejmij patelnię z ognia. Wlej masę jajeczną i energicznie mieszaj, aż powstanie kremowy sos.",
        "Podawaj natychmiast."
      ]
    }
    '''

messages = [
    {"role": "user", "content": "Przygotuj przepis na Spaghetti Carbonara."}
]

# 3. Zabezpieczenie przed błędem wersji (Pydantic V1 vs V2) przy schemacie
try:
    schema = Dish.model_json_schema() # Pydantic V2
except AttributeError:
    schema = Dish.schema()            # Pydantic V1

functions = [{
    "name": "Dish",
    "parameters": schema
}]

# 4. Wywołanie mockowanego API
function_call_arguments = call_api(messages, functions)

# 5. Zabezpieczenie przed błędem wersji (Pydantic V1 vs V2) przy parsowaniu
try:
    przepis = Dish.model_validate_json(function_call_arguments) # Pydantic V2
except AttributeError:
    przepis = Dish.parse_raw(function_call_arguments)           # Pydantic V1

# 6. Wyświetlenie wyników
print(f"=== {przepis.dish.upper()} ===\n")

print("SKŁADNIKI:")
for sk in przepis.ingredients:
    print(f" - {sk}")

print("\nPRZYGOTOWANIE:")
for i, krok in enumerate(przepis.steps, 1):
    print(f" {i}. {krok}")
