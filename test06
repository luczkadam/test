from pydantic import BaseModel, Field
from enum import Enum
from typing import List

# 1. Definicja Enum dla atrybutów (ograniczenie wyboru modelu do konkretnych opcji)
class AttributeName(str, Enum):
    COLOR = "kolor"
    SIZE = "rozmiar"
    MATERIAL = "materiał"
    BRAND = "marka"

# 2. Struktura dla pojedynczego atrybutu
class Attribute(BaseModel):
    name: AttributeName = Field(description="Nazwa atrybutu wybrana z listy")
    value: str = Field(description="Wartość atrybutu wyekstrahowana z tekstu")

# 3. Główna struktura zbierająca listę atrybutów
class ProductAttributes(BaseModel):
    attributes: List[Attribute]

# 4. Symulacja odpowiedzi z modelu (zgodnie z formatem na screenach)
mocked_llm_output = '''
{
  "attributes": [
    {"name": "kolor", "value": "czerwony"},
    {"name": "rozmiar", "value": "XL"},
    {"name": "materiał", "value": "bawełna"}
  ]
}
'''

# 5. Parsowanie i walidacja
try:
    product = ProductAttributes.model_validate_json(mocked_llm_output)
except AttributeError:
    product = ProductAttributes.parse_raw(mocked_llm_output)

# 6. Wyświetlenie wyników
for attr in product.attributes:
    print(f"{attr.name.value.capitalize()}: {attr.value}")
