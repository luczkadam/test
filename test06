import json

system_prompt = """
Wygeneruj listę zakupów w formacie JSON dla przepisu na naleśniki. 
Zwróć WYŁĄCZNIE poprawny obiekt JSON z głównym kluczem 'zakupy', zawierającym listę obiektów z polami: 'produkt', 'ilość', 'jednostka'.
"""

def mock_llm_call(prompt: str) -> str:
    # Symulujemy odpowiedź, którą normalnie wygenerowałoby AI
    return '''
    {
      "zakupy": [
        {"produkt": "mąka pszenna", "ilość": 250, "jednostka": "g"},
        {"produkt": "mleko", "ilość": 500, "jednostka": "ml"},
        {"produkt": "jajka", "ilość": 2, "jednostka": "szt."},
        {"produkt": "olej", "ilość": 3, "jednostka": "łyżki"},
        {"produkt": "sól", "ilość": 1, "jednostka": "szczypta"}
      ]
    }
    '''

messages = [
    {"role": "system", "content": system_prompt}
]

# Symulacja wywołania API
response_text = mock_llm_call(messages[0]["content"])

# Parsowanie i ładne wyświetlenie wyniku
parsed_json = json.loads(response_text)
print(json.dumps(parsed_json, indent=2, ensure_ascii=False))
