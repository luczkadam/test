from pydantic import BaseModel, Field
from typing import List

# 1. Struktura dla pojedynczej propozycji z uzasadnieniem (Reasoner)
class Reasoner(BaseModel):
    proposition: str = Field(description="Główne stwierdzenie lub propozycja")
    explainer: List[str] = Field(description="Lista argumentów lub uzasadnień dla propozycji")

# 2. Główna struktura zadania
class TaskResponse(BaseModel):
    propositions: List[Reasoner]

# 3. Symulacja odpowiedzi z modelu (zgodnie z formatem na screenach)
mocked_llm_output = '''
{
  "propositions": [
    {
      "proposition": "Wprowadzenie automatycznej weryfikacji maili",
      "explainer": [
        "Skraca czas obsługi zgłoszeń przez pracowników o 30%.",
        "Eliminuje błędy ludzkie przy ręcznej klasyfikacji.",
        "Pozwala na natychmiastowe blokowanie znanych domen spamowych."
      ]
    },
    {
      "proposition": "Integracja z systemem CRM",
      "explainer": [
        "Umożliwia pełny wgląd w historię kontaktów z klientem.",
        "Automatycznie aktualizuje dane w bazie po każdej interakcji."
      ]
    }
  ]
}
'''

# 4. Parsowanie i walidacja
try:
    data = TaskResponse.model_validate_json(mocked_llm_output)
except AttributeError:
    data = TaskResponse.parse_raw(mocked_llm_output)

# 5. Wyświetlenie wyników
for item in data.propositions:
    print(f"Propozycja: {item.proposition}")
    print("Uzasadnienie:")
    for point in item.explainer:
        print(f" - {point}")
    print("-" * 30)
