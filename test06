import json
from jinja2 import Environment

env = Environment()
env.filters["as_json"] = lambda v: json.dumps(v, indent=2, ensure_ascii=False)

user_profile = {"user_id": "u-12345", "last_order": "Margherita", "payment": "karta"}

template = env.from_string("""Jesteś asystentem pizzerii. Zbierz: rodzaj pizzy, rozmiar, adres, telefon, płatność.
Profil klienta:
{{ user_profile | as_json }}""")

print(template.render(user_profile=user_profile))
