from pydantic import BaseModel, Field

# 1. Definicja struktury adresowej
class Address(BaseModel):
    street: str = Field(description="Nazwa ulicy")
    building_number: str = Field(description="Numer budynku/domu")
    city: str = Field(description="Miasto")
    zip_code: str = Field(description="Kod pocztowy")

# 2. Symulacja odpowiedzi z modelu (zgodnie z formatem na screenach)
mocked_llm_output = '''
{
  "street": "Marszałkowska",
  "building_number": "10/12",
  "city": "Warszawa",
  "zip_code": "00-001"
}
'''

# 3. Parsowanie i walidacja
try:
    address = Address.model_validate_json(mocked_llm_output)
except AttributeError:
    address = Address.parse_raw(mocked_llm_output)

# 4. Wyświetlenie zwalidowanych danych
print("--- WYEKSTRAHOWANY ADRES ---")
print(f"Ulica: {address.street}")
print(f"Numer: {address.building_number}")
print(f"Miasto: {address.city}")
print(f"Kod:   {address.zip_code}")
