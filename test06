from pydantic import BaseModel, Field

# 1. Definicja struktury z polami spam_reason oraz not_spam_reason
class SpamClassification(BaseModel):
    # Field(description="...") to świetny sposób, by podpowiedzieć modelowi AI, czego od niego oczekujemy
    spam_reason: str = Field(description="Why this might be spam")
    not_spam_reason: str = Field(description="Why this might be a legit message")
    is_spam: bool

# 2. Funkcja mockująca LLM (symuluje odpowiedź z wymuszonym schematem)
def mock_llm_spam_check(message: str) -> str:
    # Symulacja dla wiadomości spamowej
    if "wygrałeś" in message.lower() or "darmowy" in message.lower():
        return '''
        {
            "spam_reason": "Wiadomość obiecuje darmową wygraną, wymusza pośpiech (PILNE!) i zawiera podejrzany link.",
            "not_spam_reason": "Istnieje minimalna szansa, że użytkownik brał udział w konkursie, o którym zapomniał.",
            "is_spam": true
        }
        '''
    # Symulacja dla zwykłej wiadomości
    else:
        return '''
        {
            "spam_reason": "Krótka treść może przypominać zautomatyzowane wiadomości od botów.",
            "not_spam_reason": "To standardowa, naturalnie brzmiąca prośba o zmianę terminu spotkania biznesowego.",
            "is_spam": false
        }
        '''

# 3. Przykładowe wiadomości
messages_to_test = [
    "PILNE! Wygrałeś najnowszego smartfona! Kliknij w poniższy link: http://scam-strona.xyz",
    "Cześć, czy moglibyśmy przełożyć nasze jutrzejsze spotkanie na godzinę 14:00? Pozdrawiam."
]

# 4. Wykonanie i wyświetlenie wyników
for msg in messages_to_test:
    print(f"Treść wiadomości: '{msg}'")
    
    # Symulacja pobrania wyniku z LLM w formacie JSON
    json_response = mock_llm_spam_check(msg)
    
    # Walidacja Pydantic (kompatybilność z V1 i V2)
    try:
        result = SpamClassification.model_validate_json(json_response)
    except AttributeError:
        result = SpamClassification.parse_raw(json_response)
        
    # Wyświetlenie wyników
    print("ANALIZA:")
    print(f" - Dlaczego to może być SPAM:  {result.spam_reason}")
    print(f" - Dlaczego to może być LEGIT: {result.not_spam_reason}")
    print(f" - Ostateczna decyzja:         {'🔴 SPAM' if result.is_spam else '🟢 NIE SPAM'}")
    print("-" * 60 + "\n")
