import json
from pydantic import BaseModel, Field
from typing import List, Optional

# 1. Struktura dla prostych pytań i odpowiedzi (np. Q&A przed wyjazdem)
class QuestionAnswer(BaseModel):
    question: str
    answer: str

# 2. Struktura zagnieżdżona odpowiadająca za "co" (proposition) i "dlaczego" (explainer)
class Reasoner(BaseModel):
    proposition: str = Field(
        ..., 
        description="A statement or assertion that is being reasoned about. This is the main claim or proposition."
    )
    explainer: List[str] = Field(
        ..., 
        description="An explanation or justification for the proposition. Provides reasoning or support."
    )

# 3. Główny model planera podróży
class TravelPlanner(BaseModel):
    important_questions: List[QuestionAnswer] = Field(
        ..., 
        description="A list of the most important questions to consider when planning the trip."
    )
    must_have: List[QuestionAnswer] = Field(
        ..., 
        description="A list of essential things that must be included in the trip planning."
    )
    destinations: List[Reasoner] = Field(
        ..., 
        description="A list of destinations to visit during the trip."
    )
    additional_notes: Optional[str] = Field(
        None, 
        description="Any additional notes or tips for the trip."
    )

