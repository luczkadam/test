from pydantic import BaseModel
from openai import OpenAI

class Routing(BaseModel):
    department: str
    reason: str

client = OpenAI()

system_prompt = """
1. Cel: Przekierowanie zapytania do odpowiedniego działu.
2. Kontekst: Jesteś asystentem pierwszego kontaktu.
3. Ograniczenia: Dostępne działy to: 'dział techniczny', 'dział sprzedaży', 'ogólny'.
4. Format: Zwróć obiekt z polami 'department' i 'reason'.
5. Długość: Uzasadnienie (reason) to maksymalnie jedno zdanie.
6. Ton: Profesjonalny i zwięzły.
7. Obsługa błędów: Niejasne zapytania kieruj zawsze do działu 'ogólny'.
"""

queries = [
    "Aplikacja wyrzuca błąd 500 przy logowaniu.",
    "Chciałbym kupić licencję Enterprise dla 50 osób.",
    "W jakich godzinach pracujecie?"
]

for q in queries:
    res = client.beta.chat.completions.parse(
        model="gpt-4o",
        messages=[
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": q}
        ],
        response_format=Routing
    ).choices[0].message.parsed
    
    print(f"{q}\n-> {res.department} ({res.reason})\n")
