import json

# Definicja instrukcji systemowej wymuszającej strukturę JSON
system_prompt = """
Jesteś doświadczonym szefem kuchni. Twoim zadaniem jest wygenerowanie szczegółowego przepisu kulinarnego.
Zwróć WYŁĄCZNIE poprawny obiekt JSON o następującej strukturze:
{
  "nazwa_dania": "string",
  "czas_przygotowania": "string (np. 30 minut)",
  "skladniki": ["lista", "stringów"],
  "instrukcje": ["lista", "kolejnych", "kroków"]
}
"""

def call_api(messages: list) -> str:
    # Symulacja odpowiedzi z modelu LLM (wymuszony format JSON)
    # Model na podstawie promptu użytkownika zwraca przepis na Carbonarę
    return '''
    {
      "nazwa_dania": "Spaghetti Carbonara",
      "czas_przygotowania": "20 minut",
      "skladniki": [
        "200g makaronu spaghetti",
        "100g guanciale (lub dobrej jakości boczku)",
        "2 duże jajka",
        "50g tartego sera Pecorino Romano",
        "świeżo zmielony czarny pieprz",
        "sól (tylko do wody po makaronie)"
      ],
      "instrukcje": [
        "Ugotuj makaron w mocno osolonej wodzie al dente.",
        "W międzyczasie pokrój guanciale w kostkę i podsmaż na suchej patelni na złoty kolor.",
        "W miseczce roztrzep jajka i wymieszaj je z połową startego sera oraz dużą ilością pieprzu.",
        "Odcedź makaron (zachowując pół kubka wody z gotowania) i wrzuć na patelnię z guanciale. Dokładnie wymieszaj.",
        "Zdejmij patelnię z ognia. Po chwili wlej masę jajeczno-serową, bardzo energicznie i szybko mieszając, aby powstał gęsty, kremowy sos (uważaj, by nie zrobić jajecznicy). W razie potrzeby dodaj odrobinę wody z makaronu.",
        "Podawaj natychmiast, posypane resztą sera i świeżym pieprzem."
      ]
    }
    '''

# Lista wiadomości przekazywana do "modelu"
messages = [
    {"role": "system", "content": system_prompt},
    {"role": "user", "content": "Poproszę o szczegółowy przepis na Spaghetti Carbonara."}
]

# Wywołanie funkcji
response_text = call_api(messages)

# Parsowanie i wyświetlenie wyniku w sformatowanej postaci
przepis_json = json.loads(response_text)
print(json.dumps(przepis_json, indent=2, ensure_ascii=False))
