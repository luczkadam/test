try:
    plan = TravelPlanner.model_validate_json(json_response)
except AttributeError:
    plan = TravelPlanner.parse_raw(json_response)

# 6. Formatowanie i wyświetlenie wyniku zgodnie ze zrzutem ekranu
print("[Co warto odwiedzić?]\n")

