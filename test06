import os
from pydantic import BaseModel
from openai import OpenAI

os.environ["OPENAI_API_KEY"] = "TUTAJ_WKLEJ_SWOJ_KLUCZ_API"

client = OpenAI()

class Day(BaseModel):
    title: str
    tasks: list[str]

class Plan(BaseModel):
    cot: str
    days: list[Day]

def call_api(messages, response_model):
    completion = client.beta.chat.completions.parse(
        model="gpt-4o",
        messages=messages,
        response_format=response_model
    )
    return completion.choices[0].message.parsed

system_prompt = "Jesteś organizatorem podróży. Przeanalizuj notatki używając Chain of Thought (pole 'cot'), a następnie wygeneruj uporządkowany plan w podziale na dni."

messages = [
    {"role": "system", "content": system_prompt},
    {"role": "user", "content": "Zakopane: Dolina Chochołowska. Kraków: Wawel, Stare Miasto. 3 dni góry, 2 dni miasto. Budżet 3000 zł. Obiady w centrum, pamiątki, sprawdzić bilety."}
]

response = call_api(messages, Plan)

print(f"--- ANALIZA CoT ---\n{response.cot}\n")
for d in response.days:
    print(d.title)
    for t in d.tasks:
        print(f"- {t}")
